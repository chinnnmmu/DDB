// ══════════════════════════════════════════════════════════════════
export default function App() {
  const [data, setData] = useState(null);
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);
  const [tab, setTab] = useState("overview");
  const [editBrand, setEditBrand] = useState(false);
  const [brandInput, setBrandInput] = useState("");
  const [error, setError] = useState("");
  const isMobile = useIsMobile();

  // Load all data from Sheets
  const loadAll = useCallback(async () => {
    setLoading(true); setError("");
    try {
      const d = await api("getAll");
      if (d.error) throw new Error(d.error);
      setData(d);
    } catch (e) {
      setError("⚠️ 無法連線 Google Sheets：" + e.message);
    }
    setLoading(false);
  }, []);

  useEffect(() => { loadAll(); }, [loadAll]);

  const allYears = useMemo(() => {
    if (!data) return [new Date().getFullYear()];
    const ys = new Set([new Date().getFullYear()]);
    data.dailySales.forEach(s => ys.add(new Date(s.date).getFullYear()));
    data.purchases.forEach(p => ys.add(p.year));
    return [...ys].sort((a, b) => b - a);
  }, [data]);

  // Generic action helper
  const act = async (action, body, optimisticFn) => {
    if (optimisticFn) setData(prev => optimisticFn(structuredClone(prev)));
    setSaving(true);
    try {
      const r = await api(action, body);
      if (!r.ok) throw new Error(r.msg || "失敗");
    } catch (e) {
      setError("儲存失敗：" + e.message);
      await loadAll(); // rollback
    }
    setSaving(false);
  };

  if (loading) return <div style={{ fontFamily:"'Noto Serif TC',serif", background: C.bg, minHeight:"100vh" }}><Spinner /></div>;

  if (error && !data) return (
    <div style={{ fontFamily:"'Noto Serif TC',serif", background: C.bg, minHeight:"100vh", display:"flex", alignItems:"center", justifyContent:"center", flexDirection:"column", gap:16 }}>
      <div style={{ fontSize:16, color: C.red, textAlign:"center", maxWidth:400, padding:20 }}>{error}</div>
      <div style={{ fontSize:13, color: C.muted, textAlign:"center", maxWidth:420, padding:"0 20px", lineHeight:1.7 }}>
        請確認已將 Apps Script 部署網址貼入程式頂端的 <code>SCRIPT_URL</code>
      </div>
      <Btn onClick={loadAll}>重試</Btn>
    </div>
  );

  const tabProps = { data, setData, act, loadAll, allYears, saving };

  const renderTab = () => {
    switch(tab) {
      case "overview": return <Overview {...tabProps} />;
      case "sales":    return <DailySales {...tabProps} />;
      case "purchase": return <Purchases {...tabProps} />;
      case "payroll":  return <Payroll {...tabProps} />;
      case "pnl":      return <PnL {...tabProps} />;
      case "compare":  return <YearlyCompare {...tabProps} />;
    }
  };

  const BrandArea = ({ mobile }) => editBrand ? (
    <div style={{ display:"flex", gap:8, flex:1 }}>
      <input style={{ border:`1px solid ${C.border}`, borderRadius:8, padding:"6px 10px", fontSize:13, fontFamily:"inherit", flex:1 }}
        value={brandInput} onChange={e => setBrandInput(e.target.value)} placeholder="品牌名稱" autoFocus />
      <Btn sm onClick={async () => {
        await act("setBrand", { value: brandInput }, d => { d.brandName = brandInput; return d; });
        setEditBrand(false);
      }}>儲存</Btn>
    </div>
  ) : (
    <>
      <span style={{ fontWeight:700, fontSize: mobile ? 15 : 16, color: C.tan3 }}>{data.brandName || "設定品牌名稱"}</span>
      <button onClick={() => { setBrandInput(data.brandName); setEditBrand(true); }} style={{ background:"none", border:"none", fontSize:15, cursor:"pointer", marginLeft:8 }}>✏️</button>
      {saving && <span style={{ fontSize:11, color: C.muted, marginLeft:8 }}>儲存中…</span>}
    </>
  );

  // ── MOBILE ──
  if (isMobile) return (
    <div style={{ fontFamily:"'Noto Serif TC',serif", background: C.bg, minHeight:"100vh", color: C.text }}>
      <div style={{ background: C.card, borderBottom:`1px solid ${C.border}`, padding:"12px 18px", display:"flex", alignItems:"center", position:"sticky", top:0, zIndex:20, boxShadow:"0 1px 8px rgba(140,110,82,0.08)" }}>
        <BrandArea mobile />
      </div>
      {error && <div style={{ background:"#FFF3CD", color:"#856404", padding:"8px 16px", fontSize:13 }}>{error}</div>}
      <div style={{ padding:"16px 14px", paddingBottom:90 }}>{renderTab()}</div>
      <div style={{ position:"fixed", bottom:0, left:0, right:0, background: C.card, borderTop:`1px solid ${C.border}`, display:"flex", zIndex:20, paddingBottom:"env(safe-area-inset-bottom)" }}>
        {TABS.map(t => (
          <button key={t.id} onClick={() => setTab(t.id)} style={{ flex:1, border:"none", background:"transparent", padding:"8px 0 6px", display:"flex", flexDirection:"column", alignItems:"center", gap:2, cursor:"pointer", color: tab===t.id ? C.tan2 : C.muted, borderTop: tab===t.id ? `2px solid ${C.tan2}` : "2px solid transparent", fontFamily:"inherit", transition:"all 0.15s" }}>
            <span style={{ fontSize:18 }}>{t.icon}</span>
            <span style={{ fontSize:10, fontWeight: tab===t.id?700:400 }}>{t.label}</span>
          </button>
        ))}
      </div>
    </div>
  );

  // ── DESKTOP ──
  return (
    <div style={{ fontFamily:"'Noto Serif TC',serif", background: C.bg, minHeight:"100vh", color: C.text, display:"flex" }}>
      <div style={{ width:210, background: C.card, borderRight:`1px solid ${C.border}`, display:"flex", flexDirection:"column", position:"fixed", top:0, left:0, bottom:0, zIndex:10 }}>
        <div style={{ padding:"24px 20px 18px", borderBottom:`1px solid ${C.border}` }}>
          <BrandArea />
        </div>
        <nav style={{ marginTop:10, flex:1 }}>
          {TABS.map(t => (
            <button key={t.id} onClick={() => setTab(t.id)} style={{ display:"flex", alignItems:"center", gap:10, width:"100%", textAlign:"left", padding:"12px 22px", border:"none", background: tab===t.id ? C.light : "transparent", color: tab===t.id ? C.tan3 : C.muted, fontFamily:"inherit", fontSize:14, fontWeight: tab===t.id?700:400, cursor:"pointer", borderLeft: tab===t.id ? `3px solid ${C.tan2}` : "3px solid transparent" }}>
              <span style={{ fontSize:16 }}>{t.icon}</span><span>{t.label}</span>
            </button>
          ))}
        </nav>
        <div style={{ padding:"12px 20px", borderTop:`1px solid ${C.border}`, fontSize:11, color: C.muted, textAlign:"center" }}>
          ☁️ 雲端同步至 Google Sheets
        </div>
      </div>
      <div style={{ marginLeft:210, flex:1, padding:"32px 40px" }}>
        {error && <div style={{ background:"#FFF3CD", color:"#856404", padding:"10px 16px", borderRadius:8, marginBottom:16, fontSize:13 }}>{error} <button onClick={()=>setError("")} style={{ background:"none",border:"none",cursor:"pointer",float:"right" }}>✕</button></div>}
        {renderTab()}
      </div>
    </div>
  );
}

