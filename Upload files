  const vA=gv(catA,"vendor"), vB=gv(catB,"vendor");
  const tA=catA.reduce((s,r)=>s+Number(r.amount),0);
  const tB=catB.reduce((s,r)=>s+Number(r.amount),0);

  const add = async () => {
    if (!form.vendor||!form.amount) return;
    const row={id:uuid(),year,month,...form,amount:Number(form.amount)};
    await act("addPurchase",row,d=>{d.purchases.push(row);return d;});
    setForm(f=>({...f,vendor:"",item:"",amount:""}));
